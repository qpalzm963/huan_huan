rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 僅允許讀取與上傳圖片（限制 5MB）
    // 建議未來加入 Firebase Authentication
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
